# ════════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# SERVER CONFIGURATION
PORT=5001
NODE_ENV=development

# DATABASE CONFIGURATION
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.net/chat_db?appName=Cluster0
DB_URI=mongodb+srv://<username>:<password>@cluster0.net/chat_db?appName=Cluster0

# AUTHENTICATION & SECURITY
# JWT_SECRET: Used to sign JWT tokens. Must be at least 32 characters.
# CHANGE THIS VALUE IN PRODUCTION!
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_for_production

# CONSTELLATION AUTH PEPPER
# REQUIRED: A strong, random secret used as pepper during constellation pattern hashing.
# Must be at least 32 characters. Store securely in production — changing this invalidates all constellation patterns.
# CHANGE THIS VALUE IN PRODUCTION!
CONSTELLATION_PEPPER=change_this_to_a_strong_random_secret_minimum_32_chars

# STARWEAVE BIOMETRIC SECRET
# REQUIRED: A dedicated secret for the Stellar Cipher biometric verification.
STARWEAVE_SECRET=change_this_to_a_strong_random_secret_minimum_32_chars

# CLOUDINARY IMAGE UPLOADS
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET_KEY=your_cloudinary_secret_key

# SPOTIFY INTEGRATION (for premium listening features)
# OAuth credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5001/api/spotify/auth/callback

# FRONTEND CORS CONFIGURATION
FRONTEND_URL=http://localhost:5173

# DEVELOPMENT MODE TOGGLES
# WARNING: Only use DEV_AUTH_BYPASS=true in development environments
DEV_AUTH_BYPASS=false

# OPTIONAL: EMAIL SERVICE (for password reset notifications in production)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Fill in all required values marked with REQUIRED
# 3. Never commit .env to version control
# 4. In production, use environment variables from your hosting provider
# ════════════════════════════════════════════════════════════════════════════
